# =========================
# Dashboard Data / Outputs
# =========================

# Ignore ad hoc local data drops outside the approved derived dashboard extracts.
*.csv
*.tsv
*.xlsx
*.parquet
*.feather
*.rds

# Track the selected dashboard-ready extracts copied from the analysis repo.
!input/derived_data/*.csv

# Keep generated dashboard artifacts local, while preserving directory scaffolding.
output/screenshots/*
!output/screenshots/.gitkeep
output/exports/*
!output/exports/.gitkeep
output/logs/*
!output/logs/.gitkeep


